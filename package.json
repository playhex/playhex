{
  "homepage": "https://playhex.org",
  "description": "Play Hex board game online",
  "license": "AGPL-3.0-only",
  "author": "Julien Maulny",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/playhex/playhex.git"
  },
  "workspaces": [
    "src/shared/pixi-board"
  ],
  "type": "module",
  "exports": "./index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "hex": "NODE_OPTIONS='--import=./register.js' TS_NODE_PROJECT=\"src/server/tsconfig.json\" ts-node src/server/commands",
    "analyse-size": "NODE_ENV=production vite build --mode analysis",
    "lint": "yarn build && eslint && vue-tsc -p src/client --noEmit",
    "start": "node index.js",
    "start:prod": "NODE_ENV=production node index.js",
    "build-client": "NODE_ENV=production vite build",
    "build-server": "tsc -b src/server",
    "dev-server": "tsc-watch --noClear -b ./src/server/tsconfig.json --onSuccess \"node --enable-source-maps --trace-warnings index.js\"",
    "dev-server-debug": "tsc-watch --noClear -b ./src/server/tsconfig.json --onSuccess \"node --inspect --enable-source-maps index.js\"",
    "open-browser": "wait-on http://localhost:${PORT:-3000} && node -e \"import('open').then(m=>m.default('http://localhost:'+(process.env.PORT||3000)))\"",
    "serve": "concurrently -n \"SERVER,BROWSER\" \"yarn dev-server\" \"yarn open-browser\"",
    "serve:prod": "yarn build && yarn start:prod",
    "build": "concurrently --prefix \"[{name}]\" --names \"SERVER,CLIENT\" -c \"bgBlue.bold,bgGreen.bold\" \"yarn build-server\" \"yarn build-client\"",
    "typeorm": "TS_NODE_PROJECT=src/server/tsconfig.json typeorm-ts-node-esm -d src/server/data-source.ts",
    "test:unit": "NODE_OPTIONS='--import=./register.js' TS_NODE_PROJECT=\"src/shared/tsconfig.json\" mocha 'src/**/**/**/test/**/**/**/*.ts' src/shared/**/*.spec.ts src --extension ts --ignore 'src/**/node_modules/**' --ignore 'src/**/pixi-board/**'",
    "test:e2e": "yarn hex check-tests-requirements && concurrently --kill-others --names SERVER,CYPRESS \"yarn serve:prod\" \"wait-on http://localhost:${PORT:-3000} && yarn cypress run --browser firefox\"",
    "test:all": "yarn test:unit && yarn test:e2e",
    "test": "yarn test:unit"
  },
  "dependencies": {
    "@flystorage/file-storage": "^1.2.2",
    "@flystorage/local-fs": "^1.2.0",
    "@influxdata/influxdb3-client": "^2.1.0",
    "@overlastic/vue": "^0.8.3",
    "@playhex/pixi-board": "*",
    "@popperjs/core": "^2.11.8",
